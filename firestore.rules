rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // 取得 team member 文件
    function getMember(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)/members/$(uid())).data;
    }

    function isTeamMember(teamId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(uid()));
    }

    function isTeamAdmin(teamId) {
      return isTeamMember(teamId) &&
        getMember(teamId).role in ['owner', 'admin'];
    }

    function isTeamOwner(teamId) {
      return isTeamMember(teamId) &&
        getMember(teamId).role == 'owner';
    }

    function isInitialOwnerCreate(teamId, memberId) {
      return isSignedIn()
        && uid() == memberId
        && request.resource.data.uid == uid()
        && request.resource.data.role == 'owner'
        && get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy == uid()
        && !exists(/databases/$(database)/documents/teams/$(teamId)/members/$(memberId));
    }

    // ─── Global Users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && uid() == userId;
      allow write: if isSignedIn() && uid() == userId;
    }

    // ─── Memberships（已停用） ─────────────────────────────────────────────────
    match /memberships/{docId} {
      allow read, write: if false;
    }

    // ─── Teams ─────────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      allow read: if isTeamMember(teamId);
      allow create: if isSignedIn();
      allow update: if isTeamAdmin(teamId);
      allow delete: if isTeamOwner(teamId);

      // Members
      match /members/{memberId} {
        allow read: if isTeamMember(teamId);
        // 只允許 team 建立者在建團隊當下建立 owner 成員
        allow create: if isInitialOwnerCreate(teamId, memberId);
        allow update, delete: if isTeamAdmin(teamId);
      }

      // Invitations
      match /invitations/{token} {
        allow read: if true; // 邀請連結需公開讀取（驗證 token 有效）
        allow create, update: if isTeamAdmin(teamId);
        allow delete: if isTeamAdmin(teamId);
      }

      // Sessions
      match /sessions/{sessionId} {
        allow read: if isTeamMember(teamId);
        allow create, update, delete: if isTeamAdmin(teamId);

        // Comments
        match /comments/{commentId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId) &&
            request.resource.data.userId == uid();
          allow update: if isTeamMember(teamId) &&
            (uid() == resource.data.userId || isTeamAdmin(teamId));
          allow delete: if isTeamMember(teamId) &&
            (uid() == resource.data.userId || isTeamAdmin(teamId));
        }
      }

      // Swap Requests
      match /swaps/{swapId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId) &&
          request.resource.data.requesterId == uid();
        allow update, delete: if isTeamAdmin(teamId);
      }

      // Audit Logs（只讀）
      match /auditLogs/{logId} {
        allow read: if isTeamAdmin(teamId);
        allow write: if false;
      }

      // Availabilities
      match /availabilities/{availId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId) && uid() == request.resource.data.userId;
        allow delete: if isTeamMember(teamId) && uid() == resource.data.userId;
        allow update: if false;
      }
    }

    // ─── invitations_index（停用，避免任意污染） ────────────────────────────────
    match /invitations_index/{token} {
      allow read, write: if false;
    }
  }
}
